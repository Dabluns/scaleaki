DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxx.supabase.co:5432/postgres"

# Supabase Storage (para upload/delete de arquivos)
# Obter em: Supabase Dashboard → Settings → API → Project API keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ⚠️ BACKEND ONLY - JAMAIS usar prefixo NEXT_PUBLIC_ para esta variável!
# Ignora RLS policies e tem acesso administrativo total ao storage.
# Obter em: Supabase Dashboard → Settings → API → Project API keys → service_role (Reveal)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Connection Pooling (recomendado para produção - usar porta 6543)
# DATABASE_URL_POOLED="postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxx.supabase.co:6543/postgres?pgbouncer=true"

# SQLite (somente para desenvolvimento/testes)
# DATABASE_URL="file:./admin.db"

# JWT
JWT_SECRET="Qw8!zP2@rT7vL6$kN9^bS4&xM1*eJ5%uH0adadfawrd34ef344"

# Redis (Cache e Fila de Emails)
# Opções para usar Redis:
# 1. Instalação local (Windows/Linux/Mac) - veja REDIS_SETUP.md
# 2. Serviços cloud: Redis Cloud, Upstash, AWS ElastiCache, etc.
# 3. Docker local (opcional): docker-compose up -d redis
#
# Para habilitar Redis:
# 1. Configure ENABLE_REDIS=true
# 2. Configure as credenciais abaixo conforme sua instalação
ENABLE_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Para Redis Cloud/Upstash, use a URL completa:
# REDIS_URL=redis://default:senha@host:porta

# Email (SMTP)
# Configure estas variáveis para habilitar o envio de emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=noreply@seu-dominio.com
SMTP_SECURE=false
SMTP_REJECT_UNAUTHORIZED=true

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:4000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MINUTES=15
ADMIN_RATE_LIMIT_MAX=20
ADMIN_RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_SKIP_PREFIXES=/health

# Cakto - Integração de Pagamento
# A Cakto funciona apenas com webhook, sem necessidade de credenciais de API
# Configure o webhook no dashboard da Cakto apontando para: https://seu-dominio.com/payments/webhook/cakto
# (Use BACKEND_URL para construir a URL completa do webhook)
CAKTO_CHECKOUT_URL=https://pay.cakto.com.br/checkout
CAKTO_WEBHOOK_SECRET=seu_webhook_secret_aqui

# Billing - Cobrança Recorrente e Suspensão
# Período de tolerância (em dias) antes de suspender conta por inadimplência
BILLING_GRACE_DAYS=5
# Intervalo (em milissegundos) para execução do monitor de billing (padrão: 15 minutos)
BILLING_MONITOR_INTERVAL_MS=900000
# Desabilitar monitor de billing (útil para testes ou manutenção)
# DISABLE_BILLING_MONITOR=false 