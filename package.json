{
  "name": "saas-backend",
  "version": "1.0.0",
  "description": "Backend SaaS para consultas de dados",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:both": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "build": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build && npm run build:frontend",
    "start": "node dist/server.js",
    "start:frontend": "cd frontend && npm start",
    "start:both": "concurrently \"npm start\" \"npm run start:frontend\"",
    "test": "npm run test:backend",
    "test:backend": "jest",
    "test:frontend": "cd frontend && npm test -- --runInBand",
    "test:e2e": "cd frontend && npm run test:e2e",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "create-admin": "ts-node src/scripts/createFirstAdmin.ts",
    "seed": "ts-node src/scripts/seedNichosOfertas.ts",
    "seed:exemplo": "ts-node src/scripts/seedOfertasExemplo.ts",
    "seed:staging": "ts-node src/scripts/seedStagingDataset.ts",
    "install:all": "npm install && cd frontend && npm install",
    "setup:windows": "npm install && cd frontend && npm install",
    "dev:windows": "concurrently \"npm run dev\" \"cd frontend && npm run dev\"",
    "start:windows": "concurrently \"npm start\" \"cd frontend && npm start\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.10.1",
    "@supabase/supabase-js": "^2.95.3",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^4.17.21",
    "@types/validator": "^13.15.2",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "bull": "^4.12.0",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "framer-motion": "^12.23.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "next-auth": "^4.24.11",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.1",
    "nookies": "^2.5.2",
    "pg": "^8.16.3",
    "prisma": "^6.10.1",
    "sqlite3": "^5.1.7",
    "typescript": "^5.8.3",
    "validator": "^13.15.15",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.2.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.30.0",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4",
    "lint-staged": "^16.1.2",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2"
  }
}
